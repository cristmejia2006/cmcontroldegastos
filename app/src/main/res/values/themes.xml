<resources>
    <style name="Theme.CMControlDeGastos" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Puedes cambiar el color de fondo aquí -->
        <item name="android:statusBarColor">?attr/colorPrimaryContainer</item>
    </style>

    <!-- Estilo para la pantalla de inicio (Splash) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.CMControlDeGastos</item>
    </style>
</resources>
